# Create the file
touch .gitignore
```

Paste this inside `.gitignore`:
```
# Python
__pycache__/
*.pyc
*.pyo
.env
venv/
.venv/

# AWS credentials — NEVER commit these
.aws/
credentials
config

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# Sensitive config
*.env
config.ini
secrets.json

